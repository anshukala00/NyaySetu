# =============================================================================
# Nyaysetu Case Management System - Environment Configuration Template
# =============================================================================
# Copy this file to .env and update with your actual values
# NEVER commit .env file to version control

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Example for local development:
DATABASE_URL=postgresql://nyaysetu_user:nyaysetu_pass@localhost:5432/nyaysetu

# For production, use a secure password and consider using connection pooling
# DATABASE_URL=postgresql://user:secure_password@db_host:5432/nyaysetu_prod

# =============================================================================
# JWT Authentication Configuration
# =============================================================================
# Secure JWT secret key - MUST be changed in production
# Generate using: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-secret-key-here-change-in-production

# JWT algorithm for token signing (recommended: HS256)
JWT_ALGORITHM=HS256

# JWT token expiration time in hours (default: 24 hours)
JWT_EXPIRATION_HOURS=24

# =============================================================================
# CORS Configuration
# =============================================================================
# Allowed origins for CORS (comma-separated for multiple origins)
# Development:
CORS_ORIGINS=http://localhost:3000

# Production example:
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# =============================================================================
# Application Configuration (Optional)
# =============================================================================
# Environment mode (development, staging, production)
# ENVIRONMENT=development

# API host and port
# HOST=0.0.0.0
# PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO
